    "commented_code": "\"dompurify\": \"3.0.3\",\n     \"elkjs\": \"^0.8.2\",\n     \"khroma\": \"^2.0.0\",\n+    \"langium\": \"^1.2.0\",",
    "repo_full_name": "mermaid-js/mermaid",
    "discussion_comments": [
      {
        "comment_id": "1220083249",
        "repo_full_name": "mermaid-js/mermaid",
        "pr_number": 4450,
        "pr_file": "packages/mermaid/package.json",
        "discussion_id": "1220083249",
        "commented_code": "@@ -62,8 +62,10 @@\n     \"dompurify\": \"3.0.3\",\n     \"elkjs\": \"^0.8.2\",\n     \"khroma\": \"^2.0.0\",\n+    \"langium\": \"^1.2.0\",",
        "comment_created_at": "2023-06-06T17:56:34+00:00",
        "comment_author": "msujew",
        "comment_body": "Another, **very important** info: Langium does not follow semantic versioning (we should probably put this up on a banner on our repo). Due to Langium's architecture, every change that touches any signature of any method/class/interface is automatically breaking. You will definitely get in trouble using `^`. We do take care of bugfix releases and ensure that these are non-breaking. I would therefore recommend to replace `^1.2.0` with either `~1.2.0` or straight up `1.2.0`. This applies to both `langium` and `langium-cli`",
        "pr_file_module": null
      },
      {
        "comment_id": "1220777279",
        "repo_full_name": "mermaid-js/mermaid",
        "pr_number": 4450,
        "pr_file": "packages/mermaid/package.json",
        "discussion_id": "1220083249",
        "commented_code": "@@ -62,8 +62,10 @@\n     \"dompurify\": \"3.0.3\",\n     \"elkjs\": \"^0.8.2\",\n     \"khroma\": \"^2.0.0\",\n+    \"langium\": \"^1.2.0\",",
        "comment_created_at": "2023-06-07T03:26:47+00:00",
        "comment_author": "sidharthv96",
        "comment_body": "As it's a core dependency, I think we should stick with fixed version like `1.2.0`.",
        "pr_file_module": null
      },
      {
        "comment_id": "1220780619",
        "repo_full_name": "mermaid-js/mermaid",
        "pr_number": 4450,
        "pr_file": "packages/mermaid/package.json",
        "discussion_id": "1220083249",
        "commented_code": "@@ -62,8 +62,10 @@\n     \"dompurify\": \"3.0.3\",\n     \"elkjs\": \"^0.8.2\",\n     \"khroma\": \"^2.0.0\",\n+    \"langium\": \"^1.2.0\",",
        "comment_created_at": "2023-06-07T03:31:25+00:00",
        "comment_author": "sidharthv96",
        "comment_body": "Done. ",
        "pr_file_module": null
      }
    ]
